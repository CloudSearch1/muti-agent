# IntelliTeam 配置文件示例

# 复制此文件为 .env 并填入实际值

# ============ LLM 配置 ============
LLM_PROVIDER=openai
LLM_MODEL=gpt-3.5-turbo
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=60

# API Keys（请替换为实际值）
LLM_OPENAI_API_KEY=sk-your-openai-api-key
LLM_ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
LLM_DASHSCOPE_API_KEY=sk-your-dashscope-api-key

# 缓存
LLM_USE_CACHE=true
LLM_CACHE_TTL=3600
LLM_SEMANTIC_CACHE_THRESHOLD=0.9

# ============ 数据库配置 ============
DB_URL=sqlite+aiosqlite:///./intelliteam.db
# 生产环境建议使用 PostgreSQL
# DB_URL=postgresql+asyncpg://user:password@localhost:5432/intelliteam

DB_POOL_SIZE=50
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=1800
DB_POOL_TIMEOUT=10
DB_ECHO=false

# ============ Redis 配置 ============
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=50

# ============ Agent 配置 ============
AGENT_CODER_MODEL=gpt-4
AGENT_CODER_LANGUAGE=python
AGENT_CODER_STYLE=pep8

AGENT_TESTER_FRAMEWORK=pytest
AGENT_TESTER_COVERAGE_TARGET=80

AGENT_DOC_FORMAT=markdown

AGENT_ARCHITECT_PATTERNS=["MVC", "微服务"]

AGENT_TIMEOUT_SECONDS=300
AGENT_MAX_RETRIES=3

# ============ API 配置 ============
API_HOST=0.0.0.0
API_PORT=8080
API_WORKERS=4
API_DEBUG=false

API_CORS_ORIGINS=["*"]
API_RATE_LIMIT=60
API_GZIP_MIN_SIZE=1000

# ============ 日志配置 ============
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_FILE=logs/intelliteam.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ============ 安全配置 ============
# 生产环境务必修改此值！
SECURITY_SECRET_KEY=change-me-in-production
SECURITY_ALGORITHM=HS256
SECURITY_ACCESS_TOKEN_EXPIRE_MINUTES=30

SECURITY_ENABLE_AUDIT=true
SECURITY_AUDIT_LOG_FILE=logs/audit.log

# ============ 应用配置 ============
APP_NAME=IntelliTeam
APP_VERSION=2.0.0
APP_DESCRIPTION=智能研发协作平台
APP_ENVIRONMENT=development
