# IntelliTeam 环境变量配置模板
# 复制此文件为 .env 并填入实际值

# ===========================================
# 应用配置
# ===========================================
APP_NAME=IntelliTeam
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ===========================================
# LLM 配置 - 阿里云 CodePlan (推荐)
# ===========================================
# 阿里云百炼 (CodePlan) - 通义千问
OPENAI_API_KEY=sk-sp-fcc6b74dd3da4321b3a788a62b9fca6b
OPENAI_API_BASE=https://coding.dashscope.aliyuncs.com/v1
OPENAI_MODEL=qwen3.5-plus

# ===========================================
# LLM 配置 - OpenAI (可选)
# ===========================================
# OPENAI_API_KEY=sk-xxx
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4

# ===========================================
# LLM 配置 - Azure OpenAI (可选)
# ===========================================
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_DEPLOYMENT=

# ===========================================
# 数据库配置
# ===========================================
# PostgreSQL
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/intelliteam

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# ===========================================
# 向量数据库配置
# ===========================================
# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=

# ===========================================
# 嵌入模型配置
# ===========================================
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cuda  # cuda / cpu
EMBEDDING_DIMENSION=1024

# Reranker
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ===========================================
# Agent 配置
# ===========================================
AGENT_MAX_ITERATIONS=10
AGENT_TIMEOUT_SECONDS=300
AGENT_TEMPERATURE=0.3

# ===========================================
# API 配置
# ===========================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# JWT (可选)
JWT_SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ===========================================
# 知识库配置 (可选)
# ===========================================
# CONFLUENCE_URL=
# CONFLUENCE_USER=
# CONFLUENCE_TOKEN=

# JIRA_URL=
# JIRA_USER=
# JIRA_TOKEN=

# GITLAB_URL=
# GITLAB_TOKEN=
