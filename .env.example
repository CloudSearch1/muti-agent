# IntelliTeam 环境配置模板
# 复制此文件为 .env 并填写实际值
# cp .env.example .env

# ==============================================================================
# LLM 配置
# ==============================================================================

# OpenAI API 配置 (推荐)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# 阿里云百炼 API 配置 (可选)
# OPENAI_API_KEY=sk-your-qwen-api-key-here
# OPENAI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# OPENAI_MODEL=qwen3.5-plus

# LLM 通用配置
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=60

# ==============================================================================
# 数据库配置
# ==============================================================================

# PostgreSQL 数据库 (推荐)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/intelliteam

# SQLite 数据库 (开发环境)
# DATABASE_URL=sqlite+aiosqlite:///./intelliteam.db

# 数据库连接池配置
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# ==============================================================================
# Redis 配置
# ==============================================================================

REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50
REDIS_TIMEOUT=5

# Celery 消息队列 (如果使用)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ==============================================================================
# API 服务配置
# ==============================================================================

API_HOST=0.0.0.0
API_PORT=8000

# 是否开启 Swagger UI 和 ReDoc
API_DOCS_ENABLED=true

# CORS 配置
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# ==============================================================================
# Web UI 配置
# ==============================================================================

# Web UI 端口 (如果使用独立前端)
WEBUI_PORT=3000

# ==============================================================================
# 安全配置
# ==============================================================================

# JWT 密钥 (必须修改!)
SECRET_KEY=your-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# 密码加密
BCRYPT_ROUNDS=12

# ==============================================================================
# 监控配置
# ==============================================================================

# Prometheus 监控
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ==============================================================================
# 功能开关
# ==============================================================================

# 是否启用缓存
CACHE_ENABLED=true
CACHE_TTL=300

# 是否启用 Agent 系统
AGENTS_ENABLED=true

# 是否启用 MCP 工具
MCP_TOOLS_ENABLED=true

# ==============================================================================
# 开发环境配置
# ==============================================================================

# 开发模式
DEBUG=false

# 热重载 (开发环境)
RELOAD=false

# ==============================================================================
# 性能调优
# ==============================================================================

# 请求超时 (秒)
REQUEST_TIMEOUT=30

# 并发限制
MAX_CONCURRENT_REQUESTS=100

# 任务队列超时 (秒)
TASK_TIMEOUT=300

# ==============================================================================
# 第三方集成
# ==============================================================================

# GitHub API (用于代码工具)
GITHUB_TOKEN=your-github-token-here

# 企业微信/钉钉 Webhook (用于通知)
WEBHOOK_URL=

# ==============================================================================
# 测试配置
# ==============================================================================

# 测试数据库
TEST_DATABASE_URL=sqlite+aiosqlite:///./test.db

# 是否启用测试模式
TESTING=false

# ==============================================================================
# 其他配置
# ==============================================================================

# 项目版本
PROJECT_VERSION=1.0.0

# 默认 Agent 配置
DEFAULT_AGENT_MODEL=qwen3.5-plus
DEFAULT_AGENT_TEMPERATURE=0.3

# ==============================================================================
# 配置说明
# ==============================================================================

# 必需配置 (没有默认值):
# - OPENAI_API_KEY: 必须填写你的 API 密钥
# - SECRET_KEY: 必须修改为随机字符串
# - DATABASE_URL: 根据你的数据库配置修改
# - REDIS_URL: 根据你的 Redis 配置修改

# 推荐修改:
# - API_PORT: 如果 8000 端口被占用
# - LOG_LEVEL: 生产环境建议设置为 WARNING 或 ERROR
# - DEBUG: 生产环境必须设置为 false

# 开发环境建议:
# - DEBUG=true
# - LOG_LEVEL=DEBUG
# - RELOAD=true
# - API_DOCS_ENABLED=true

# 生产环境建议:
# - DEBUG=false
# - LOG_LEVEL=WARNING
# - RELOAD=false
# - API_DOCS_ENABLED=false (或限制访问)
# - 使用 PostgreSQL 而非 SQLite
# - 配置独立的 Redis 实例

# ==============================================================================
# 配置验证
# ==============================================================================

# 启动服务前，请确保:
# 1. 所有必需配置已填写
# 2. SECRET_KEY 已修改为随机字符串
# 3. 数据库和 Redis 服务已启动
# 4. API 密钥有效

# 配置完成后，启动服务:
# python start.py
# 或
# python cli.py start
